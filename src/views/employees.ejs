<!-- views/employees.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee List - EJS Rendering Example</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 40px 20px;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }

        h1 {
            color: #333;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        h1 span {
            background: #667eea;
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.5em;
        }

        .stats {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .stats-item {
            text-align: center;
        }

        .stats-label {
            font-size: 0.9em;
            opacity: 0.9;
            margin-bottom: 5px;
        }

        .stats-number {
            font-size: 2em;
            font-weight: bold;
        }

        .employee-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .employee-card {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 20px;
            transition: all 0.3s ease;
            border: 1px solid #e9ecef;
        }

        .employee-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.2);
            border-color: #667eea;
        }

        .employee-name {
            font-size: 1.3em;
            font-weight: bold;
            color: #333;
            margin-bottom: 10px;
            border-bottom: 2px solid #667eea;
            padding-bottom: 5px;
        }

        .employee-job {
            color: #666;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .employee-job:before {
            content: '💼';
            margin-right: 5px;
        }

        .employee-id {
            font-size: 0.8em;
            color: #999;
            background: #e9ecef;
            padding: 5px 10px;
            border-radius: 5px;
            display: inline-block;
            word-break: break-all;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #999;
        }

        .empty-state:before {
            content: '👥';
            font-size: 4em;
            display: block;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        .actions {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 2px dashed #e9ecef;
            display: flex;
            gap: 10px;
            justify-content: center;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 1em;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .btn-primary {
            background: #667eea;
            color: white;
        }

        .btn-primary:hover {
            background: #5a67d8;
            transform: translateY(-2px);
        }

        .btn-secondary {
            background: #48bb78;
            color: white;
        }

        .btn-secondary:hover {
            background: #38a169;
            transform: translateY(-2px);
        }

        .footer {
            text-align: center;
            margin-top: 20px;
            color: #999;
            font-size: 0.9em;
        }

        .timestamp {
            color: #667eea;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>
            👥 Employee Management System
            <span>EJS Rendering</span>
        </h1>

        <% if (employees && employees.length > 0) { %>
            <div class="stats">
                <div class="stats-item">
                    <div class="stats-label">Total Employees</div>
                    <div class="stats-number"><%= employees.length %></div>
                </div>
                <div class="stats-item">
                    <div class="stats-label">Last Updated</div>
                    <div class="stats-number"><%= new Date().toLocaleTimeString() %></div>
                </div>
            </div>

            <div class="employee-grid">
                <% employees.forEach(function(emp) { %>
                    <div class="employee-card">
                        <div class="employee-name">
                            <%= emp.name %>
                        </div>
                        <div class="employee-job">
                            <%= emp.job || 'Position not specified' %>
                        </div>
                        <div class="employee-id">
                            ID: <%= emp._id %>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <h2>No Employee Data</h2>
                <p>Click the button below to add your first employee</p>
            </div>
        <% } %>

        <div class="actions">
            <a href="/employees" class="btn btn-primary" target="_blank">📋 View API Data</a>
            <button onclick="window.location.reload()" class="btn btn-secondary">🔄 Refresh Page</button>
        </div>

        <div class="footer">
            ⏰ Page rendered at: <span class="timestamp"><%= new Date().toLocaleString() %></span>
        </div>
    </div>
</body>
</html>